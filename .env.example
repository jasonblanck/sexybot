# ── Wallet / Polymarket auth ───────────────────────────────────────────────────
PRIVATE_KEY=0x_your_32byte_hex_wallet_private_key
POLYMARKET_FUNDER=0x_your_gnosis_safe_proxy_address   # omit if using EOA directly

# Polymarket L2 API creds — derived automatically on first run if omitted
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_API_PASSPHRASE=your_polymarket_passphrase

# ── Trading config ─────────────────────────────────────────────────────────────
STRATEGY=momentum             # momentum | market_making
DRY_RUN=true                  # set false for live orders
MAX_ORDER_SIZE=10             # max USDC per trade
KELLY_FRACTION=0.25           # quarter-kelly (0.25 recommended)
DAILY_LOSS_LIMIT=500          # bot stops for the day above this total spend
PROFIT_TARGET=0.08            # base profit target (scaled by entry price + regime)
STOP_LOSS=0.05                # base stop-loss (scaled by entry price + regime)
# Time-stop: exit stalled positions after this many seconds if they haven't hit
# profit/stop and the gain is <= TIME_STOP_MIN_GAIN. Recycles capital into
# fresher signals and caps slow-bleed losses that never trigger a %-stop.
MAX_HOLD_SEC=3600
TIME_STOP_MIN_GAIN=-0.01
# Pure-OBI fallback threshold — when there is no trade-volume spike, require
# this much |OBI| before trading on book imbalance alone. Raised from 0.35 to
# reject quiet-market false positives.
OBI_SOLO_MIN=0.55
# Minimum top-5 order-book depth (both sides combined, USDC) required before
# trading a market. Thin books produce unreliable signals and slip our edge.
MIN_BOOK_DEPTH_USDC=200
# Hard ceiling on the side we're buying (BUY YES → fill ≈ best_ask;
# BUY NO → fill ≈ 1 - best_bid). Above this, the ask side is typically
# empty and FOK BUYs reject as "no_match", piling up status="error"
# trades. Also: at 0.97+ the upside is sub-3¢ and not worth the risk.
MAX_ENTRY_PRICE=0.97
# Self-learning loop (main_v2.py).
# CALIBRATOR_ENABLED: apply Brier-score-based bias correction to predicted
# probabilities. No-op until ≥30 resolved trades with a matching source are
# written to brier_scores.
CALIBRATOR_ENABLED=true
CALIBRATION_SOURCE=momentum_v2
# REGIME_RESPECT: read bot.py's latest regime_log entry and throttle:
#   normal   → no change
#   cautious → Kelly × 0.5, OBI-only signals skipped
#   hostile  → skip momentum entries (exits still run)
REGIME_RESPECT=true
# Optional override for the shared calibration DB (defaults to ./trades.db):
# CALIBRATION_DB_PATH=/root/polybot/trades.db
SCAN_INTERVAL=30              # legacy — not currently read; see SCAN_INTERVAL_S
# Anthropic-spend throttles. The 60s/35-conf settings still burned ~$28/day
# (over the $25 budget below). Bumping scan to 120s halves remaining call
# volume, and AI_MIN_CONFIDENCE=50 cuts the long tail of low-conviction
# pretrade checks (which had aborted/downsized 0 times in 24h — pure cost).
SCAN_INTERVAL_S=120           # seconds between trading cycles
AI_MIN_CONFIDENCE=50          # signals below this don't trigger analyze_with_claude
# Cancel any open Polymarket orders left from a previous run on startup.
# Default true is the safe choice — prevents orphan orders from filling
# silently while the bot has no memory of them. Set false only if you
# intentionally want to hand off open orders across restarts.
STARTUP_CANCEL_OPEN=true
# Daily Telegram digest — fires once per UTC day with trade count,
# realized P&L, Claude spend, and top/worst category. Requires
# TELEGRAM_TOKEN + TELEGRAM_CHAT_ID. Silent no-op otherwise.
DAILY_SUMMARY=true
DAILY_SUMMARY_UTC_HOUR=23      # 0-23
DAILY_SUMMARY_UTC_MIN=55       # 0-59
# Alert if today's Anthropic-API spend exceeds this. One Telegram ping per
# UTC day. Set 0 to disable. Requires TELEGRAM_TOKEN + TELEGRAM_CHAT_ID.
CLAUDE_DAILY_BUDGET_USD=25

# Market Making (only used when STRATEGY=market_making)
MM_HALF_SPREAD=0.02           # half-spread in probability units (0.02 = 4¢ total)
MM_ORDER_SIZE=5.0             # USDC per leg per quote

# Drawdown kill-switch
MAX_DRAWDOWN_USD=50           # halt if balance drops $50 from recent peak
DRAWDOWN_WINDOW=600           # rolling window in seconds (600 = 10 min)

# Balance-error circuit breaker (retry-storm guard). After N "not enough
# balance" errors inside the rolling window, pause all order placement for
# the pause duration. Added after the 2026-04-09 retry storm.
BALANCE_ERROR_LIMIT=5         # trip after this many errors
BALANCE_ERROR_WINDOW=600      # rolling window in seconds (600 = 10 min)
BALANCE_ERROR_PAUSE=900       # pause duration after trip (900 = 15 min)

# Categories to skip at discovery (comma-separated, case-insensitive
# substring match on market.category). Defaults to 'crypto' per the
# 2026-04-22 backtest — short-horizon crypto price markets are
# structurally efficient and showed 0% win rate. Override with '' to
# re-enable.
EXCLUDE_CATEGORIES=crypto
# Keywords to skip at discovery (comma-separated, case-insensitive
# substring match on market.question and market.slug). Polymarket's
# `category` field puts most political/geopolitical markets under
# "other", so excluding them needs to happen on the question text.
# Default list reflects the bot's biggest historical losses
# (Iran diplomatic-meeting −87%, uranium −78%, etc.). Override with
# '' to re-enable.
EXCLUDE_KEYWORDS=iran,uranium,ukraine,russia,taiwan,diplomatic,nuclear,sanctions,trump,newsom,desantis,election,impeach,supreme court,fed chair

# ── Bot API security ──────────────────────────────────────────────────────────
API_SECRET_KEY=change_this_to_something_strong_random

# ── Dashboard view-password ───────────────────────────────────────────────────
# Gates the /login.html → cookie auth → dashboard flow. Separate from
# API_SECRET_KEY (which protects *write* endpoints). Change from the default.
DASHBOARD_PASSWORD=SEXYBOT
SESSION_TTL_SEC=604800    # 7 days — login cookie lifetime

# Paper trading
PAPER_MODE=false
PAPER_BALANCE=1000

# ── Claude Max features (model, regime detector, nightly review) ──────────────
# CLAUDE_MODEL drives both analyze_with_claude and nightly_strategy_review.
# Sonnet 4.6 ($3/$15 per 1M) is the recommended default — markedly better than
# Haiku on ambiguous political/legal/macro markets. Fall back to Haiku
# (CLAUDE_MODEL=claude-haiku-4-5) to halve the cost at some quality cost.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5     # used for regime detector + fallback
CLAUDE_ADAPTIVE_THINK=true             # enables adaptive thinking on Sonnet/Opus
REGIME_DETECTOR=true                   # hourly Claude check that gates trading
NIGHTLY_REVIEW=true                    # daily Claude review of yesterday's trades
PRETRADE_CHECK=true                    # pre-order Haiku sanity read of current book
PRETRADE_MIN_USD=3.0                   # skip pretrade check below this order size
PRETRADE_TIMEOUT_S=4.0                 # hard timeout — proceed at full size on miss
DEEP_ANALYZE=true                      # Opus + web_search verification on big trades
DEEP_ANALYZE_MIN_USD=20.0              # only trades ≥ this trigger deep analysis
DEEP_ANALYZE_MODEL=claude-opus-4-6     # strongest reasoning for high-stakes verify
DEEP_ANALYZE_TIMEOUT_S=45.0            # hard timeout — keep fast decision if slow
AUTO_APPLY_REVIEW=false                # auto-apply low-risk nightly recs (off by default)
AUTO_APPLY_MIN_CONF=70                 # review confidence needed to auto-apply
AUTO_APPLY_MAX_DELTA=0.25              # max % change from current value (0.25 = ±25%)
BACKTEST_WEEKLY=true                   # Sunday 01:00 UTC Claude Code Execution backtest

# Emergency kill switch: set to true to disable ALL Claude Max features at
# once. The bot keeps trading on its rule-based strategies. Use during an
# Anthropic outage, if you spot a bad AI pattern, or to run the legacy path
# for a day. Flip back to false and restart to re-enable everything.
CLAUDE_MAX_DISABLE=false

# ── External APIs ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Claude AI for market analysis
FRED_API_KEY=your_fred_api_key      # Federal Reserve economic data
FMP_API_KEY=your_fmp_api_key        # Financial Modeling Prep (macro data)
TAVILY_API_KEY=tvly-...             # News search for AI signal
NEWS_API_KEY=your_newsapi_key       # NewsAPI.org
ALCHEMY_API_KEY=your_alchemy_key    # Polygon RPC (fallback)
COINGECKO_API_KEY=your_cg_key       # Crypto price data
FINNHUB_API_KEY=your_finnhub_key    # Real-time US stock quotes (AI context)
OPENROUTER_API_KEY=your_or_key      # Stored for future use (Anthropic fallback)
POLYGON_API_KEY=your_polygon_key    # Stock quotes fallback when Finnhub fails

# Telegram alerts (optional)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

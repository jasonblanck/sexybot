# Polymarket Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── SECURITY (REQUIRED) ────────────────────────────────────────────────────
# Secret key for the REST API and WebSocket (X-Api-Key header / ?api_key=)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BOT_API_KEY=

# Comma-separated list of origins allowed to call the API via browser
# Example: https://myapp.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Set to "true" to enable /docs and /redoc (keep off in production)
DOCS_ENABLED=false

# ─── BLOCKCHAIN / POLYMARKET ────────────────────────────────────────────────
# Your Ethereum/Polygon wallet private key (starts with 0x)
PRIVATE_KEY=

# Optional: pre-existing Polymarket L2 API credentials
# Leave blank to have the bot derive them automatically from PRIVATE_KEY
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Optional: funder address (needed for proxy/gnosis-safe wallets)
POLYMARKET_FUNDER=

# ─── BOT SETTINGS ───────────────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Trading strategy: momentum | meanReversion | arbitrage | marketMaking
STRATEGY=momentum

# Maximum USDC per order
MAX_ORDER_SIZE=10

# Set to "false" only when you are ready to trade real funds
DRY_RUN=true

# ─── THIRD-PARTY API KEYS ───────────────────────────────────────────────────
# Federal Reserve Economic Data (FRED) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Open-Meteo (optional, free tier works without a key)
OPEN_METEO_API_KEY=

# ─── SERVER ─────────────────────────────────────────────────────────────────
# Bind address — use 127.0.0.1 (localhost) and put nginx/caddy in front
HOST=127.0.0.1
PORT=8000
